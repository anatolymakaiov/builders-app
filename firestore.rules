rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function userPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function hasUserDoc() {
      return signedIn() && exists(userPath(uid()));
    }

    function role() {
      return hasUserDoc() ? get(userPath(uid())).data.role : null;
    }

    function isAdmin() {
      return role() == "admin";
    }

    function isEmployer() {
      return role() == "employer";
    }

    function isWorker() {
      return role() == "worker";
    }

    function isSelf(userId) {
      return signedIn() && uid() == userId;
    }

    function isHeldData(data) {
      return ("moderationHold" in data && data.moderationHold == true)
        || ("profileSuspended" in data && data.profileSuspended == true)
        || ("profileHold" in data && data.profileHold == true)
        || ("accountOnHold" in data && data.accountOnHold == true)
        || ("status" in data && data.status in ["suspended", "on_hold"]);
    }

    function isUserHeld(userId) {
      return userId is string
        && exists(userPath(userId))
        && isHeldData(get(userPath(userId)).data);
    }

    function isJobHeldData(data) {
      return ("moderationHold" in data && data.moderationHold == true)
        || ("vacancyHold" in data && data.vacancyHold == true)
        || ("jobSuspended" in data && data.jobSuspended == true)
        || ("status" in data && data.status in ["suspended", "on_hold"])
        || ("moderationStatus" in data && data.moderationStatus == "on_hold");
    }

    function isPublicJob(data) {
      return data.moderationStatus == "approved"
        && (!("status" in data) || data.status in ["active", "published", "open"])
        && !isJobHeldData(data);
    }

    function isAdminMailParticipant(data) {
      return signedIn()
        && (
          data.senderId == uid()
          || data.receiverId == uid()
        );
    }

    function isOwnAdminThreadCreate(data) {
      return signedIn()
        && data.userId == uid()
        && data.createdBy == uid()
        && data.lastSenderId == uid()
        && data.participants is list
        && uid() in data.participants
        && "admin" in data.participants
        && data.threadType in ["support_request", "admin_request", "report"];
    }

    function jobPath(jobId) {
      return /databases/$(database)/documents/jobs/$(jobId);
    }

    function isJobOwner(jobId) {
      return signedIn()
        && exists(jobPath(jobId))
        && (
          get(jobPath(jobId)).data.ownerId == uid()
          || get(jobPath(jobId)).data.employerId == uid()
          || get(jobPath(jobId)).data.createdBy == uid()
          || get(jobPath(jobId)).data.userId == uid()
        );
    }

    function canSyncAcceptedOfferCounters(jobId) {
      let appId = request.resource.data.lastAcceptedApplicationId;
      let appPath = /databases/$(database)/documents/applications/$(appId);
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && appId is string
        && existsAfter(appPath)
        && getAfter(appPath).data.jobId == jobId
        && getAfter(appPath).data.status in ["offer_accepted", "accepted", "hired"]
        && (
          getAfter(appPath).data.workerId == uid()
          || getAfter(appPath).data.userId == uid()
          || (
            getAfter(appPath).data.members is list
            && uid() in getAfter(appPath).data.members
          )
        )
        && changed.hasOnly([
          "filledPositions",
          "remainingPositions",
          "openSlots",
          "availablePositions",
          "lastAcceptedApplicationId",
          "lastAcceptedCounterSyncAt",
          "updatedAt",
        ]);
    }

    function teamPath(teamId) {
      return /databases/$(database)/documents/teams/$(teamId);
    }

    function isTeamMember(teamId) {
      return signedIn()
        && teamId is string
        && exists(teamPath(teamId))
        && (
          get(teamPath(teamId)).data.ownerId == uid()
          || get(teamPath(teamId)).data.createdBy == uid()
          || (
            get(teamPath(teamId)).data.members is list
            && uid() in get(teamPath(teamId)).data.members
          )
        );
    }

    function isChatParticipant(chatId) {
      return signedIn()
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.workerId == uid()
          || get(/databases/$(database)/documents/chats/$(chatId)).data.employerId == uid()
          || get(/databases/$(database)/documents/chats/$(chatId)).data.senderId == uid()
          || get(/databases/$(database)/documents/chats/$(chatId)).data.receiverId == uid()
          || get(/databases/$(database)/documents/chats/$(chatId)).data.targetProfileId == uid()
          || (
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants is list
            && uid() in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          )
          || (
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants is map
            && uid() in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          )
          || (
            get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds is list
            && uid() in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds
          )
          || (
            get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds is map
            && uid() in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds
          )
          || (
            get(/databases/$(database)/documents/chats/$(chatId)).data.userIds is list
            && uid() in get(/databases/$(database)/documents/chats/$(chatId)).data.userIds
          )
          || (
            get(/databases/$(database)/documents/chats/$(chatId)).data.members is list
            && uid() in get(/databases/$(database)/documents/chats/$(chatId)).data.members
          )
          || (
            get(/databases/$(database)/documents/chats/$(chatId)).data.members is map
            && uid() in get(/databases/$(database)/documents/chats/$(chatId)).data.members
          )
        );
    }

    function isChatActive(chatId) {
      return exists(/databases/$(database)/documents/chats/$(chatId))
        && (
          !("canSendMessages" in get(/databases/$(database)/documents/chats/$(chatId)).data)
          || get(/databases/$(database)/documents/chats/$(chatId)).data.canSendMessages != false
        )
        && (
          !("chatStatus" in get(/databases/$(database)/documents/chats/$(chatId)).data)
          || get(/databases/$(database)/documents/chats/$(chatId)).data.chatStatus != "inactive"
        )
        && (
          !("active" in get(/databases/$(database)/documents/chats/$(chatId)).data)
          || get(/databases/$(database)/documents/chats/$(chatId)).data.active != false
        );
    }

    function isValidChatMessageCreate(chatId, messageId) {
      return isChatParticipant(chatId)
        && isChatActive(chatId)
        && !isUserHeld(uid())
        && request.resource.data.senderId == uid()
        && (
          !("chatId" in request.resource.data)
          || request.resource.data.chatId == chatId
        )
        && (
          !("messageId" in request.resource.data)
          || request.resource.data.messageId == messageId
        );
    }

    match /users/{userId} {
      allow create: if signedIn() && (isSelf(userId) || isAdmin());
      allow read: if signedIn();
      allow update: if isAdmin() || isSelf(userId);
      allow delete: if isAdmin() || isSelf(userId);

      match /notifications/{notificationId} {
        allow create: if signedIn();
        allow read, update, delete: if isAdmin() || isSelf(userId);
      }

      match /admin_inbox/{messageId} {
        allow create, delete: if isAdmin();
        allow read, update: if isAdmin() || isSelf(userId);
      }

      match /portfolio/{portfolioId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin() || isSelf(userId);
      }

      match /reviews/{reviewId} {
        allow create: if signedIn();
        allow read: if signedIn();
        allow update, delete: if isAdmin() || isSelf(userId);
      }

      match /legalAcceptances/{documentId} {
        allow create, read, update: if isAdmin() || isSelf(userId);
        allow delete: if isAdmin() || isSelf(userId);
      }

      match /billing/{billingDocId} {
        allow read, create, update: if isAdmin() || isSelf(userId);
        allow delete: if isAdmin();

        match /invoices/{invoiceId} {
          allow read, create, update: if isAdmin() || isSelf(userId);
          allow delete: if isAdmin();
        }
      }

      match /job_alerts/{alertId} {
        allow create: if isAdmin()
          || (
            isSelf(userId)
            && request.resource.data.userId == uid()
          );
        allow read, update, delete: if isAdmin() || isSelf(userId);
      }
    }

    match /pending_registrations/{userId} {
      allow create, read, update, delete: if isAdmin() || isSelf(userId);

      match /legalAcceptances/{documentId} {
        allow create, read, update, delete: if isAdmin() || isSelf(userId);
      }
    }

    match /saved_jobs/{userId}/jobs/{jobId} {
      allow create, read, update, delete: if isAdmin() || isSelf(userId);
    }

    match /jobs/{jobId} {
      allow create: if isAdmin()
        || (
          isEmployer()
          && !isUserHeld(uid())
          && request.resource.data.ownerId == uid()
        );
      allow read: if signedIn()
        && (
          isAdmin()
          || resource.data.ownerId == uid()
          || resource.data.employerId == uid()
          || resource.data.createdBy == uid()
          || resource.data.userId == uid()
          || isPublicJob(resource.data)
        );
      allow update: if isAdmin()
        || (
          isEmployer()
          && !isUserHeld(uid())
          && (
            resource.data.ownerId == uid()
            || resource.data.employerId == uid()
            || resource.data.createdBy == uid()
            || resource.data.userId == uid()
          )
        )
        || canSyncAcceptedOfferCounters(jobId);
      allow delete: if isAdmin()
        || (
          isEmployer()
          && !isUserHeld(uid())
          && (
            resource.data.ownerId == uid()
            || resource.data.employerId == uid()
            || resource.data.createdBy == uid()
            || resource.data.userId == uid()
          )
        );
    }

    match /applications/{applicationId} {
      allow create: if signedIn()
        && !isUserHeld(uid())
        && (
          isAdmin()
          ||
          !(request.resource.data.jobId is string)
          || !exists(jobPath(request.resource.data.jobId))
          || (
            isPublicJob(get(jobPath(request.resource.data.jobId)).data)
            &&
            !isJobHeldData(get(jobPath(request.resource.data.jobId)).data)
            && !isUserHeld(get(jobPath(request.resource.data.jobId)).data.ownerId)
            && !isUserHeld(get(jobPath(request.resource.data.jobId)).data.employerId)
          )
        )
        && (
          isAdmin()
          || request.resource.data.workerId == uid()
          || request.resource.data.employerId == uid()
          || request.resource.data.ownerId == uid()
          || isJobOwner(request.resource.data.jobId)
          || (request.resource.data.members is list && uid() in request.resource.data.members)
        );
      allow get: if signedIn()
        && (
          !exists(/databases/$(database)/documents/applications/$(applicationId))
          || isAdmin()
          || resource.data.workerId == uid()
          || resource.data.employerId == uid()
          || resource.data.ownerId == uid()
          || isJobOwner(resource.data.jobId)
          || (resource.data.members is list && uid() in resource.data.members)
          || isTeamMember(resource.data.teamId)
        );
      allow list: if isAdmin()
        || resource.data.workerId == uid()
        || resource.data.employerId == uid()
        || resource.data.ownerId == uid()
        || isJobOwner(resource.data.jobId)
        || (resource.data.members is list && uid() in resource.data.members)
        || isTeamMember(resource.data.teamId);
      allow update, delete: if isAdmin()
        || resource.data.workerId == uid()
        || resource.data.employerId == uid()
        || resource.data.ownerId == uid()
        || isJobOwner(resource.data.jobId)
        || (resource.data.members is list && uid() in resource.data.members)
        || isTeamMember(resource.data.teamId);
    }

    match /chats/{chatId} {
      allow create: if signedIn();
      allow read: if signedIn();
      allow update: if isAdmin()
        || resource.data.workerId == uid()
        || resource.data.employerId == uid()
        || resource.data.senderId == uid()
        || resource.data.receiverId == uid()
        || resource.data.targetProfileId == uid()
        || (resource.data.participants is list && uid() in resource.data.participants)
        || (resource.data.participants is map && uid() in resource.data.participants)
        || (resource.data.participantIds is list && uid() in resource.data.participantIds)
        || (resource.data.participantIds is map && uid() in resource.data.participantIds)
        || (resource.data.userIds is list && uid() in resource.data.userIds)
        || (resource.data.members is list && uid() in resource.data.members)
        || (resource.data.members is map && uid() in resource.data.members);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow create: if isAdmin()
          || isValidChatMessageCreate(chatId, messageId);
        allow read: if isAdmin() || isChatParticipant(chatId);
        allow update: if isAdmin() || isChatParticipant(chatId);
        allow delete: if isAdmin();
      }
    }

    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.fromUserId == uid()
        && request.resource.data.status == "open";
      allow read: if isAdmin() || resource.data.fromUserId == uid();
      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.fromUserId == uid()
          && request.resource.data.fromUserId == uid()
        );
      allow delete: if isAdmin();
    }

    match /phoneIndex/{phoneId} {
      allow get: if true;
      allow list: if false;
      allow create, update: if signedIn()
        && (
          isAdmin()
          || request.resource.data.uid == uid()
          || request.resource.data.userId == uid()
          || request.resource.data.previousUserId == uid()
        );
      allow delete: if isAdmin();
    }

    match /emailIndex/{emailId} {
      allow get: if true;
      allow list: if false;
      allow create, update: if signedIn()
        && (
          isAdmin()
          || request.resource.data.uid == uid()
          || request.resource.data.userId == uid()
          || request.resource.data.previousUserId == uid()
        );
      allow delete: if isAdmin();
    }

    match /registrationPhoneIndex/{phoneId} {
      allow get: if true;
      allow list: if false;
      allow create, update: if signedIn()
        && (
          isAdmin()
          || request.resource.data.uid == uid()
          || request.resource.data.userId == uid()
          || request.resource.data.previousUserId == uid()
        );
      allow delete: if isAdmin();
    }

    match /registrationEmailIndex/{emailId} {
      allow get: if true;
      allow list: if false;
      allow create, update: if signedIn()
        && (
          isAdmin()
          || request.resource.data.uid == uid()
          || request.resource.data.userId == uid()
          || request.resource.data.previousUserId == uid()
        );
      allow delete: if isAdmin();
    }

    match /support_requests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.userId == uid()
        && request.resource.data.status == "open";
      allow read: if isAdmin() || resource.data.userId == uid();
      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.userId == uid()
          && request.resource.data.userId == uid()
        );
      allow delete: if isAdmin();
    }

    match /admin_inbox_messages/{messageId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /admin_messages/{messageId} {
      allow read: if isAdmin() || isAdminMailParticipant(resource.data);
      allow create: if isAdmin()
        || (
          signedIn()
          && request.resource.data.senderId == uid()
          && request.resource.data.receiverId == "admin"
        );
      allow update: if isAdmin() || isAdminMailParticipant(resource.data);
      allow delete: if isAdmin();
    }

    match /message_threads/{threadId} {
      allow read: if isAdmin()
        || (signedIn() && uid() in resource.data.participants);
      allow create: if isAdmin()
        || isOwnAdminThreadCreate(request.resource.data)
        || (
          signedIn()
          && request.resource.data.participants is list
          && uid() in request.resource.data.participants
          && "admin" in request.resource.data.participants
          && request.resource.data.lastSenderId == uid()
        );
      allow update: if isAdmin()
        || (signedIn() && uid() in resource.data.participants);
      allow delete: if isAdmin();
    }

    match /message_attachments/{attachmentId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        || (
          signedIn()
          && request.resource.data.senderId == uid()
          && request.resource.data.threadId is string
        );
      allow update, delete: if isAdmin();
    }

    match /unread_counters/{counterId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin()
        || (signedIn() && counterId == "admin");
      allow delete: if isAdmin();
    }

    match /payment_requests/{requestId} {
      allow create: if isEmployer()
        && request.resource.data.employerId == uid()
        && request.resource.data.status == "pending";
      allow read: if isAdmin() || resource.data.employerId == uid();
      allow update, delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow create: if isAdmin()
        || (
          isEmployer()
          && request.resource.data.employerId == uid()
          && request.resource.data.status in ["issued", "pending"]
          && request.resource.data.paymentStatus == "payment_required"
        );
      allow update, delete: if isAdmin();
      allow read: if isAdmin() || resource.data.employerId == uid();
    }

    match /payments/{paymentId} {
      allow create, update, delete: if isAdmin();
      allow read: if isAdmin() || resource.data.employerId == uid();
    }

    match /billing_schedules/{scheduleId} {
      allow create, update, delete: if isAdmin();
      allow read: if isAdmin() || resource.data.employerId == uid();
    }

    match /plans/{planId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /job_alerts/{alertId} {
      allow create: if signedIn() && request.resource.data.userId == uid();
      allow read, update, delete: if isAdmin() || resource.data.userId == uid();
    }

    match /teams/{teamId} {
      allow create: if signedIn()
        && (
          request.resource.data.createdBy == uid()
          || (
            request.resource.data.members is list
            && uid() in request.resource.data.members
          )
        );
      allow read: if signedIn();
      allow update: if isAdmin()
        || resource.data.createdBy == uid()
        || resource.data.ownerId == uid()
        || (resource.data.members is list && uid() in resource.data.members);
      allow delete: if isAdmin()
        || resource.data.createdBy == uid()
        || resource.data.ownerId == uid();

      match /portfolio/{portfolioId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin()
          || get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy == uid()
          || get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == uid()
          || (
            get(/databases/$(database)/documents/teams/$(teamId)).data.members is list
            && uid() in get(/databases/$(database)/documents/teams/$(teamId)).data.members
          );
      }
    }

    match /portfolio/{portfolioId} {
      allow create: if signedIn()
        && (
          request.resource.data.userId == uid()
          || request.resource.data.teamId is string
        );
      allow read: if signedIn();
      allow update, delete: if isAdmin()
        || resource.data.userId == uid();
    }

    match /reviews/{reviewId} {
      allow create: if signedIn();
      allow read: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin()
        || resource.data.userId == uid()
        || resource.data.workerId == uid()
        || resource.data.employerId == uid();
    }
  }
}
