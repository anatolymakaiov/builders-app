rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isChatParticipant(chatId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/chats/$(chatId))
        && (
          firestore.get(/databases/(default)/documents/chats/$(chatId)).data.workerId == request.auth.uid
          || firestore.get(/databases/(default)/documents/chats/$(chatId)).data.employerId == request.auth.uid
          || (
            firestore.get(/databases/(default)/documents/chats/$(chatId)).data.participants is list
            && request.auth.uid in firestore.get(/databases/(default)/documents/chats/$(chatId)).data.participants
          )
          || (
            firestore.get(/databases/(default)/documents/chats/$(chatId)).data.participantIds is list
            && request.auth.uid in firestore.get(/databases/(default)/documents/chats/$(chatId)).data.participantIds
          )
          || (
            firestore.get(/databases/(default)/documents/chats/$(chatId)).data.members is list
            && request.auth.uid in firestore.get(/databases/(default)/documents/chats/$(chatId)).data.members
          )
          || firestore.get(/databases/(default)/documents/chats/$(chatId)).data.targetProfileId == request.auth.uid
        );
    }

    match /profile_photos/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /profile_headers/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /company_photos/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /job_photos/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /portfolio/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /team_avatars/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /team_portfolio/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /chat_media/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /chat_audio/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /chat_video/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /chat_voice/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /chat_attachments/{chatId}/{messageId}/{senderId}/{fileName} {
      allow read: if isChatParticipant(chatId);
      allow write: if isChatParticipant(chatId)
        && request.auth.uid == senderId;
    }

    match /admin_mail/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /billing_invoices/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /{allPaths=**} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}
