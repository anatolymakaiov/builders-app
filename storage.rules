rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /profile_photos/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /profile_headers/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /company_photos/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /job_photos/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /portfolio/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /team_avatars/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /team_portfolio/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /chat_media/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /chat_audio/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /chat_video/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /chat_voice/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /chat_attachments/{chatId}/{messageId}/{senderId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn()
        && request.auth.uid == senderId;
    }

    match /support_requests/{userId}/{fileName} {
      allow read: if signedIn()
        && (request.auth.uid == userId || request.auth.token.admin == true);
      allow write: if signedIn()
        && request.auth.uid == userId;
    }

    match /admin_mail/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /billing_invoices/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /{allPaths=**} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}
