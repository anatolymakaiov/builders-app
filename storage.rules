rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isChatParticipant(chatId) {
      let chat = firestore.get(/databases/(default)/documents/chats/$(chatId));
      return signedIn()
        && chat != null
        && (
          chat.data.workerId == request.auth.uid
          || chat.data.employerId == request.auth.uid
          || chat.data.senderId == request.auth.uid
          || chat.data.receiverId == request.auth.uid
          || chat.data.targetProfileId == request.auth.uid
          || (
            chat.data.participants is list
            && request.auth.uid in chat.data.participants
          )
          || (
            chat.data.participants is map
            && request.auth.uid in chat.data.participants
          )
          || (
            chat.data.participantIds is list
            && request.auth.uid in chat.data.participantIds
          )
          || (
            chat.data.participantIds is map
            && request.auth.uid in chat.data.participantIds
          )
          || (
            chat.data.userIds is list
            && request.auth.uid in chat.data.userIds
          )
          || (
            chat.data.members is list
            && request.auth.uid in chat.data.members
          )
          || (
            chat.data.members is map
            && request.auth.uid in chat.data.members
          )
        );
    }

    match /profile_photos/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /profile_headers/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /company_photos/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /job_photos/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /portfolio/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /team_avatars/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /team_portfolio/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /chat_media/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /chat_audio/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /chat_video/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /chat_voice/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /chat_attachments/{chatId}/{messageId}/{senderId}/{fileName} {
      allow read: if isChatParticipant(chatId);
      allow write: if isChatParticipant(chatId)
        && request.auth.uid == senderId;
    }

    match /admin_mail/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /billing_invoices/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /{allPaths=**} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}
